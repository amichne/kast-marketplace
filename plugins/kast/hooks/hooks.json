{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"$PLUGIN_ROOT/scripts/kast-codex-hook\" session-start",
            "timeout": 130,
            "statusMessage": "Preparing Kast and background IntelliJ for this worktree"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Read|apply_patch|Edit|Write|mcp__filesystem__read_file",
        "hooks": [
          {
            "type": "command",
            "command": "\"$PLUGIN_ROOT/scripts/kast-codex-hook\" pre-tool-use",
            "timeout": 10,
            "statusMessage": "Checking for a Kast or Graphify semantic path"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$PLUGIN_ROOT/scripts/kast-codex-hook\" post-tool-use",
            "timeout": 70,
            "statusMessage": "Checking changed Kotlin files with Kast"
          }
        ]
      }
    ]
  }
}
